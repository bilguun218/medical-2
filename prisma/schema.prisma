generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Locale {
  MN
  EN
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum InquiryStatus {
  NEW
  IN_REVIEW
  REPLIED
  CLOSED
}

enum MediaType {
  IMAGE
  PDF
  DOCUMENT
}

enum ProductMediaRole {
  GALLERY
  DATASHEET
  CERTIFICATE
  BROCHURE
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(EDITOR)
  accounts      Account[]
  sessions      Session[]
  articles      Article[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ProductCategory {
  id            String    @id @default(cuid())
  slug          String    @unique
  titleMn       String
  titleEn       String
  descriptionMn String?   @db.Text
  descriptionEn String?   @db.Text
  sortOrder     Int       @default(0)
  products      Product[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Product {
  id               String          @id @default(cuid())
  slug             String          @unique
  categoryId       String
  titleMn          String
  titleEn          String?
  tag              String?
  summaryMn        String?         @db.Text
  summaryEn        String?         @db.Text
  descriptionMn    String?         @db.Text
  descriptionEn    String?         @db.Text
  specifications   Json?
  seoTitleMn       String?
  seoTitleEn       String?
  seoDescriptionMn String?         @db.Text
  seoDescriptionEn String?         @db.Text
  status           PublishStatus   @default(DRAFT)
  publishedAt      DateTime?
  category         ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  media            ProductMedia[]
  inquiries        ContactInquiry[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model ProductMedia {
  id        String           @id @default(cuid())
  productId String
  mediaId   String
  role      ProductMediaRole @default(GALLERY)
  sortOrder Int              @default(0)
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  media     Media            @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([productId, mediaId, role])
}

model NewsCategory {
  id            String    @id @default(cuid())
  slug          String    @unique
  titleMn       String
  titleEn       String
  descriptionMn String?   @db.Text
  descriptionEn String?   @db.Text
  articles      Article[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Article {
  id               String        @id @default(cuid())
  slug             String        @unique
  categoryId       String?
  authorId         String?
  titleMn          String
  titleEn          String?
  excerptMn        String?       @db.Text
  excerptEn        String?       @db.Text
  bodyMn           String        @db.Text
  bodyEn           String?       @db.Text
  coverImageId     String?
  seoTitleMn       String?
  seoTitleEn       String?
  seoDescriptionMn String?       @db.Text
  seoDescriptionEn String?       @db.Text
  status           PublishStatus @default(DRAFT)
  publishedAt      DateTime?
  category         NewsCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author           User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  coverImage       Media?        @relation(fields: [coverImageId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Media {
  id             String         @id @default(cuid())
  type           MediaType
  url            String
  filename       String
  altMn          String?
  altEn          String?
  mimeType       String
  size           Int
  productMedia   ProductMedia[]
  articleCovers  Article[]
  createdAt      DateTime       @default(now())
}

model ContactInquiry {
  id          String        @id @default(cuid())
  name        String
  organization String?
  email       String
  phone       String?
  subject     String
  message     String        @db.Text
  productId   String?
  status      InquiryStatus @default(NEW)
  product     Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SeoSetting {
  id              String   @id @default(cuid())
  route           String   @unique
  titleMn         String?
  titleEn         String?
  descriptionMn   String?  @db.Text
  descriptionEn   String?  @db.Text
  canonicalPath   String?
  ogImage         String?
  noIndex         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
